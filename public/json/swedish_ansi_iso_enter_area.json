{
    "title": "Swedish ANSI keyboard ISO-style Enter area",
    "rules": [
        {
            "description": "Return and Backslash to Enter, with Shift+Backslash as * and Option+Backslash as '",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "return_or_enter"
                    },
                    "to": [
                        {
                            "key_code": "keypad_enter"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "backslash",
                        "modifiers": {
                            "mandatory": [
                                "shift"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "keypad_asterisk"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "backslash",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "backslash"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "backslash",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "keypad_enter"
                        }
                    ]
                }
            ]
        }
    ]
}
