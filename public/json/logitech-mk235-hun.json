              "key_code": "mute"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "f10"
          },
          "to": [
            {
              "key_code": "volume_decrement"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "f11"
          },
          "to": [
            {
              "consumer_key_code": "volume_increment"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "f12"
          },
          "to": [
            {
              "key_code": "4",
              "modifiers": ["left_shift", "left_command"]
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
