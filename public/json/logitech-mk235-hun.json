          "from": {
            "key_code": "f5"
          },
          "to": [
            {
              "key_code": "launchpad"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "f6"
          },
          "to": [
            {
              "consumer_key_code": "rewind"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "f7"
          },
          "to": [
