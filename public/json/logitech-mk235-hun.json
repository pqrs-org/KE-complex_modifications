{
  "title": "Logitech MK235 HUN",
  "maintainers": ["sanyacode"],
  "rules": [
    {
      "description": "Special symbols on MK235 Hungarian keyboard layout are matching.",
      "manipulators": [
        {
          "from": {
            "key_code": "q",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "hyphen",
              "modifiers": ["right_option"]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "non_us_backslash",
              "modifiers": ["right_option"]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "v",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "q",
              "modifiers": ["right_option"]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "non_us_backslash",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "z",
              "modifiers": ["right_option", "right_shift"]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "z",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
