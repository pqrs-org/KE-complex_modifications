          "from": {
            "key_code": "9",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "b",
              "modifiers": ["right_option", "right_shift"]
            }
          ],
          "type": "basic"
        },
