          "from": {
            "key_code": "f3"
          },
          "to": [
            {
              "shell_command": "open 'https://www.google.com'"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "f4"
          },
          "to": [
            {
              "shell_command": "open '/System/Applications/Calculator.app'"
            }
          ],
          "type": "basic"
        },
