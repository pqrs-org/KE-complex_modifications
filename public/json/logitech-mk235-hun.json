              "key_code": "x",
              "modifiers": ["right_option", "right_shift"]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "x",
            "modifiers": {
              "mandatory": ["right_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "3",
              "modifiers": ["right_option", "right_shift"]
            }
