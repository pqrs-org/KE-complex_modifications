{
  "title": "Remap the punctuation & symbols for a virtual Slovene keyboard-layout back to the punctuation & symbol layout of a US/ANSI/ABC keyboard",
  "maintainers": ["FToThe3rdPower"],
  "rules": [
    {
      "description": "Remaps the number row as well as the keys between m & the right shift keys such that <1234567890/+,.->!\"#$%&'()=?*;:_  becomes  `1234567890-=,./~!@#$%^&*()_+<>?",
      "manipulators": [

        {
          "type": "basic",
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "grave_accent_and_tilde", "modifiers": ["left_option"] },
            { "key_code": "spacebar" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "n", "modifiers": ["left_option"] },
            { "key_code": "spacebar" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "2",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "2", "modifiers": ["left_option", "left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "6",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "i", "modifiers": ["left_option"] },
            { "key_code": "spacebar" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "7",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "6", "modifiers": ["left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "0",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "9", "modifiers": ["left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "hyphen",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "slash" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "hyphen",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "slash", "modifiers": ["left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "equal_sign",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "0", "modifiers": ["left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "equal_sign",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "equal_sign" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "comma",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "grave_accent_and_tilde" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "period",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "grave_accent_and_tilde", "modifiers": ["left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "slash",
            "modifiers": { "mandatory": ["shift"], "optional": ["caps_lock"] }
          },
          "to": [
            { "key_code": "hyphen", "modifiers": ["left_shift"] }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [{ "input_source_id": "com.apple.keylayout.Slovenian" }]
            }
          ]
        }

      ]
    }
  ]
}
