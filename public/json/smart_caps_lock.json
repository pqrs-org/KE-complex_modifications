{
  "title": "Smart Caps Lock",
  "maintainers": ["vbwx"],
  "rules": [
    {
        "description": "CapsLock -> Esc, Shift + CapsLock -> CapsLock, CapsLock + AnyKey -> Ctrl + AnyKey",
        "manipulators": [
            {
                "from": {
                    "key_code": "caps_lock",
                    "modifiers": {
                        "mandatory": ["shift"],
                        "optional": ["caps_lock"]
                    }
                },
                "to": [{ "key_code": "caps_lock" }],
                "type": "basic"
            },
            {
                "from": {
                    "key_code": "caps_lock",
                    "modifiers": { "optional": ["any"] }
                },
                "to": [
                    {
                        "key_code": "left_control",
                        "lazy": true
                    }
                ],
                "to_if_alone": [{ "key_code": "escape" }],
                "type": "basic"
            }
        ]
    }
  ]
}
