{
    "description": "Remap option+x to command+q, to close applications on macOS.",
    "maintainers": [
        "SergioInToronto"
    ],
    "manipulators": [
        {
            "from": {
                "key_code": "x",
                "modifiers": { "mandatory": ["left_option"] }
            },
            "to": [
                {
                    "key_code": "q",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        }
    ]
}
