{
  "title": "Final Cut Pro: Productivity Power Pack",
  "maintainers": ["thecarlo"],
  "rules": [
    {
      "description": "Final Cut Pro: mouse button 3 → horizontal timeline scroll (hold to drag, release to revert to select tool)",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": ["^com\\.apple\\.FinalCut$"],
              "type": "frontmost_application_if"
            }
          ],
          "from": { "pointing_button": "button3" },
          "to": [{ "key_code": "h" }, { "pointing_button": "button1" }],
          "to_after_key_up": [{ "key_code": "a" }],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Final Cut Pro: left ctrl + left click → trim start (option + [)",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": ["^com\\.apple\\.FinalCut$"],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "modifiers": {
              "mandatory": ["left_control"],
              "optional": []
            },
            "pointing_button": "button1"
          },
          "to": [
            {
              "key_code": "open_bracket",
              "modifiers": ["left_option"]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Final Cut Pro: left ctrl + right click → trim end (option + ])",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": ["^com\\.apple\\.FinalCut$"],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "modifiers": {
              "mandatory": ["left_control"],
              "optional": []
            },
            "pointing_button": "button2"
          },
          "to": [
            {
              "key_code": "close_bracket",
              "modifiers": ["left_option"]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Final Cut Pro: cmd + left click → cut (blade + click, then revert to select tool)",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": ["^com\\.apple\\.FinalCut$"],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "modifiers": {
              "mandatory": ["left_command"],
              "optional": []
            },
            "pointing_button": "button1"
          },
          "to": [{ "key_code": "b" }, { "pointing_button": "button1" }],
          "to_after_key_up": [{ "key_code": "a" }],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Final Cut Pro: shift + cmd + left click → cut across all layers (shift + cmd + b)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button1",
            "modifiers": {
              "mandatory": ["left_shift", "left_command"],
              "optional": []
            }
          },
          "to": [
            {
              "key_code": "b",
              "modifiers": ["left_shift", "left_command"]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.FinalCut$"]
            }
          ]
        }
      ]
    },
    {
      "description": "Final Cut Pro: left option + z → zoom to fit (shift + z), then zoom out (cmd + -)",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": ["^com\\.apple\\.FinalCut$"],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "key_code": "z",
            "modifiers": { "mandatory": ["left_option"] }
          },
          "to": [
            {
              "key_code": "z",
              "modifiers": ["left_shift"]
            }
          ],
          "to_after_key_up": [
            {
              "key_code": "hyphen",
              "modifiers": ["left_command"]
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
